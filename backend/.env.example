# ─── MongoDB ──────────────────────────────────────────────
# Get from https://cloud.mongodb.com → your cluster → Connect
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tripkaro

# ─── Clerk ────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# ─── Server ───────────────────────────────────────────────
PORT=5000

# ─── Frontend URL (for CORS) ──────────────────────────────
# Your Vercel deployment URL, e.g. https://tripkaro.vercel.app
FRONTEND_URL=https://your-app.vercel.app
