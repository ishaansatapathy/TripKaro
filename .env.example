# ─── Convex ───────────────────────────────────────────────
# Get this from https://dashboard.convex.dev → your project → Settings
VITE_CONVEX_URL=https://your-project.convex.cloud

# ─── Clerk ────────────────────────────────────────────────
# Get this from https://dashboard.clerk.com → your app → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# ─── Backend API ──────────────────────────────────────────
# After deploying backend to Render, paste the URL here
# e.g. https://tripkaro-backend.onrender.com
VITE_API_URL=https://your-backend.onrender.com
